# Copy to .env and fill in your values
# Never commit .env to version control

# PostgreSQL
POSTGRES_USER=gldt
POSTGRES_PASSWORD=gldt_secret
POSTGRES_DB=gdelt_risk
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Derived (auto-built from above in config.yaml)
DATABASE_SYNC_URL=postgresql://gldt:gldt_secret@localhost:5432/gdelt_risk

# Ollama (optional)
OLLAMA_URL=http://localhost:11434

# Model path
MODEL_PATH=models/checkpoints/run_phase1_best.pt

# Log level
LOG_LEVEL=INFO
